@model Help_Desk_for_Ticket_Management_System.ViewModels.LoginViewModel

<h2>Login</h2>

<form asp-action="Login" method="post">

    <div>
        <label>User ID</label>
        <input asp-for="UserId" />
    </div>

    <br />

    <div>
        <label>Password</label>
        <input asp-for="Password"
               type="password" />
    </div>

    <br />

    <button type="submit">
        Login
    </button>

</form>

@if (ViewBag.Error != null)
{
    <p style="color:red">
        @ViewBag.Error
    </p>
}